# Copy to .env for local deployment. Never commit .env.

# Mantle Sepolia public RPC fallback is configured in hardhat.config.js.
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_MAINNET_RPC_URL=https://rpc.mantle.xyz

# Deployer wallet private key with Mantle Sepolia MNT for gas.
PRIVATE_KEY=

# Explorer API key, if required by the selected verification endpoint.
MANTLE_EXPLORER_API_KEY=

# Used by scripts/submit-demo-signal.js after deployment.
SIGNAL_ARENA_ADDRESS=

